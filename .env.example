# Hephaestus Configuration
# Copy this file to .env and fill in your values

# AI Backend Selection
# Options: copilot, openai, claude, ollama
AI_BACKEND=copilot

# Model Selection (optional, defaults to backend's best model)
AI_MODEL=

# Safety Settings
DAILY_TOKEN_BUDGET=10.00
MAX_ITERATIONS=50
ERROR_THRESHOLD=5

# GitHub Copilot (if using copilot backend)
GITHUB_TOKEN=

# OpenAI (if using openai backend)
OPENAI_API_KEY=

# Anthropic Claude (if using claude backend)
ANTHROPIC_API_KEY=

# Ollama (if using ollama backend)
OLLAMA_BASE_URL=http://localhost:11434

# Project to work on (default: parent directory)
TARGET_PROJECT=../

# Logging
LOG_LEVEL=info
LOG_FILE=hephaestus.log

# Auto-commit interval in minutes (0 to disable)
AUTO_COMMIT_INTERVAL=30

# Check interval in seconds (how often to check for new tasks)
CHECK_INTERVAL=60
